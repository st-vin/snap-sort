# ── API Server ──────────────────────────────────────────────────────
# Port the Express server listens on
PORT=3001

# Your Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Expo App ─────────────────────────────────────────────────────────
# Base URL of the running API server (no trailing slash)
# When testing on a physical device, use your machine's local IP, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.x:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
